{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vocab Agent Lite",
  "version": "0.1.0",
  "identifier": "com.vocab-agent.lite",
  "build": {
    "frontendDist": "../desktop-dist",
    "devUrl": "http://localhost:3088",
    "beforeDevCommand": "npm run dev -- --turbopack --port 3088",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vocab Agent Lite",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "hiddenTitle": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Vocab Agent Lite"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      }
    }
  }
}
