{
  "name": "vocab-agent",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npx tsx scripts/ensure-registry.ts && next dev --port 3088 --disable-source-maps",
    "build": "npx tsx scripts/ensure-registry.ts && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "npx tsx src/lib/db/migrate.ts",
    "db:reset": "npx tsx src/lib/db/reset.ts",
    "clean:dynamic": "npx tsx scripts/clean-dynamic.ts",
    "clean:messages": "npx tsx scripts/clean-messages.ts",
    "purge-all": "npx tsx scripts/purge-all.ts",
    "import-ecdict": "npx tsx src/lib/dictionary/import-ecdict.ts",
    "seed-words": "npx tsx scripts/seed-words-from-ecdict.ts",
    "backfill-audio": "npx tsx src/lib/dictionary/backfill-audio.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:dev-agent": "npx tsx scripts/dev-agent-test.ts",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && cross-env ELECTRON_DEV=1 electron dist-electron/main.js",
    "electron:preview": "npm run build && npm run electron:compile && cross-env ELECTRON_PREVIEW=1 electron dist-electron/main.js",
    "electron:build": "node scripts/electron-build.js",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "postinstall": "node scripts/postinstall-patch-jiti.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@libsql/client": "^0.17.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "ai": "^7.0.29",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "ts-fsrs": "^5.4.1",
    "tw-animate-css": "^1.4.0",
    "typebox": "^1.3.6",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.11.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.7"
  }
}