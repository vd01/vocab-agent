# ═══════════════════════════════════════════════════════════════
# Vocab Agent — Environment Variables
# Copy this file to .env.local and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ── AI Model ──────────────────────────────────────────────────
# OpenAI-compatible API (used by Vercel AI SDK)
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Model names for dual-agent mode
TEACHER_MODEL=gpt-4o-mini
DEVELOPER_MODEL=gpt-4o-mini

# ── Authentication ────────────────────────────────────────────
# Simple password auth for the web UI
AUTH_PASSWORD=your-password-here
# Set to 1 to bypass auth (development only)
AUTH_BYPASS=0

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=file:./data/vocab.db

# ── DuckDNS (optional, for deploy.sh) ─────────────────────────
DUCKDNS_DOMAIN=your-domain
DUCKDNS_TOKEN=your-duckdns-token

# ── Upstash Vector (optional, for Phase 4 RAG) ────────────────
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# ═══════════════════════════════════════════════════════════════
# Debug & Development
# ═══════════════════════════════════════════════════════════════

# Word debug logger — writes per-word lookup pipeline details to data/debug/
# Includes: dictionary source results, merged entry, LLM input/output
# Default: false (no debug files generated)
WORD_DEBUG=false

# Debug panel — shows raw SSE events, tool calls, and agent state in the UI
# Default: false (panel hidden)
NEXT_PUBLIC_DEBUG_PANEL=false
