# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/reports/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local data
/data/*.db
/generated/
/src/components/generated/
/src/components/generative/component-registry.ts

# Claude Code / Omo session files
.omo/

# ECDICT submodule (large dictionary data — compressed)
#ECDICT

# dev logs
dev-server.log

# Windows scripts (local only)
restart.bat
stop.bat

# Electron build output
/dist-electron/

src-tauri/.cargo/
