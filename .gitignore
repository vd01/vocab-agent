# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts TypeScript 编译产物（scripts 用 tsx 直接运行 .ts，.js 为偶然生成的降级产物）
scripts/*.js

# local data
/data/*.db
/data/*.jsonl.gz
/data/wiktionary-import.progress
/data/mdx/
/generated/
/src/components/generated/
/src/components/generative/component-registry.ts

# Claude Code / Omo session files
.omo/

# ECDICT submodule (large dictionary data — compressed)
#ECDICT

# dev logs
dev-server.log

# Windows scripts (local only)
restart.bat
stop.bat

# pi-vocab runtime data (not tracked)
.pi-vocab/auth.json
.pi-vocab/models.json
.pi-vocab/models-store.json
.pi-vocab/npm/
.pi-vocab/sessions/
.pi-vocab/tmp/

